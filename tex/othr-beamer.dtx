% The titlegraphic requires a background pattern.
% The PowerPoint template is using a fixed size but since \pkg{othbeamer} also wants to support images of different aspect ratio we extend this mechanism to be more flexible.
%    \begin{macrocode}
\def\ps@OTHR@titlepage{
  \setbeamertemplate{background canvas}[OTHR-Titlepage]
  \@nameuse{ps@navigation}
}

\usepgflibrary{patterns.meta}

\ExplSyntaxOn
\box_if_exist:NF  \l_@@_tmpa_box {
  \box_new:N  \l_@@_tmpa_box
}
\dim_if_exist:NF  \l_@@_tmpa_dim {
  \dim_new:N  \l_@@_tmpa_dim
}
\dim_new:N \g_@@_titlegraphic_ht_dim
\dim_new:N \g_@@_titlegraphic_wd_dim
\dim_set:Nn \g_@@_titlegraphic_ht_dim {.46\paperheight}
\dim_set:Nn \g_@@_titlegraphic_wd_dim {.395\paperwidth}
\dim_const:Nn \c_@@_beamer_framesep_dim {.25\beamer@leftmargin}

\cs_new:Nn \_@@_background_pattern:n {
\par
\begingroup
\hbox_set:Nn \l_@@_tmpa_box {
  #1
}
\skip_vertical:n {1.5\c_@@_beamer_framesep_dim}
\leavevmode
\edef\@tmpa{{\dim_eval:n {\box_wd:N  \l_@@_tmpa_box +1.5\c_@@_beamer_framesep_dim}}{\dim_eval:n {\box_ht_plus_dp:N  \l_@@_tmpa_box}}}
\exp_last_unbraced:Nno \use:n {\begin{pgfpicture}{0pt}{0pt}}\@tmpa
    \pgfsetfillpattern{Lines[angle=45,yshift=-.5pt,distance=2.9pt]}{bg}
    \pgfpathrectanglecorners{\pgfpoint{0}{0}}{\exp_last_unbraced:No \pgfpoint\@tmpa}
    \pgfusepath{fill}
  \end{pgfpicture}
  \par\nointerlineskip\skip_vertical:n {-1.5\c_@@_beamer_framesep_dim-\box_ht_plus_dp:N \l_@@_tmpa_box}
  \leavevmode\box_use:N \l_@@_tmpa_box
  \par
  \endgroup
}

\cs_new:Nn \_@@_box_use_background_pattern:Nnn {
\par\skip_vertical:n {#2}
\vbox:n {
  \edef\@tmpa{{\dim_eval:n {\box_wd:N  #1 + #2}}{\dim_eval:n {\box_ht_plus_dp:N #1}}}
  \exp_last_unbraced:Nno \use:n {\begin{pgfpicture}{0pt}{0pt}}\@tmpa
      \pgfsetfillpattern{Lines[angle=45,yshift=-.5pt,distance=5pt]}{#3}
      \pgfpathrectanglecorners{\pgfpoint{#2}{0}}{\exp_last_unbraced:No \pgfpoint\@tmpa}
      \pgfusepath{fill}
    \end{pgfpicture}
    \par\nointerlineskip\skip_vertical:n {-#2-\box_ht_plus_dp:N #1}
    \box_use:N #1
  }
}

\defbeamertemplate{background~canvas}{OTHR-Titlepage}{
  \skip_horizontal:n {\beamer@leftmargin}
  \begin{beamercolorbox}[wd=\paperwidth,ht=\paperheight,dp=0pt,vmode]{background~canvas}
    \vbox_to_ht:nn {\paperheight}{
      \vskip .3\paperheight
      \vskip\dp\strutbox
      \usebeamertemplate**{titlegraphic}
      \par
      \vfill
      \leavevmode\smash{\makebox[\paperwidth][r]{
          \includegraphics[width=.2\paperwidth]{othr-beamer-title-background}
        }}
    }
  \end{beamercolorbox}
}

\defbeamertemplate*{titlegraphic}{OTHR}{%
  \_@@_background_pattern:n {
    \def\width{\g_@@_titlegraphic_wd_dim}
    \def\height{\g_@@_titlegraphic_ht_dim}
    \inserttitlegraphic
  }
  \par
}

\defbeamertemplate*{title}{OTHR}[1][]{%
  \par
  \hbox_set:Nn \l_@@_tmpa_box {
    \begin{beamercolorbox}[left,colsep=1pt,#1]{title}
      \usebeamerfont{title}\inserttitle\par%
      \ifx\insertsubtitle\@empty%
      \else%
        \vskip.65em%
        {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}%
      \fi%
    \end{beamercolorbox}
  }
  \leavevmode\makebox[0pt][r]{
    \rule[\dim_eval:n {-\box_dp:N \l_@@_tmpa_box-.4\ht\strutbox}]{1pt}{\dim_eval:n {\box_ht_plus_dp:N \l_@@_tmpa_box+1.4\ht\strutbox}}
    \skip_horizontal:n {1.3\c_@@_beamer_framesep_dim}}
  \box_use:N \l_@@_tmpa_box\par
}

\defbeamertemplate*{title~page}{OTHR}[1][]
{
  \vbox{}
  \par
  \thispagestyle{OTHR@titlepage}
  \skip_vertical:n  {.625\c_@@_beamer_framesep_dim}
\rule{.445\textwidth}{\z@}\rlap{\includegraphics[width=.456\paperwidth]{\g_@@_logofile_flat_tl}}\par
  \par
  \skip_vertical:n {4.3\c__ptxcd_beamer_framesep_dim}
  \par
  \hspace*{.398\paperwidth}\begin{beamercolorbox}[
      wd=\dim_eval:n {.6\paperwidth-2\beamer@rightmargin},
    ]{title~page}
    \setlength{\textwidth}{\linewidth}
    \usebeamertemplate{title}
  \end{beamercolorbox}
}[action]{
  \iffalse
  \setbeamertemplate{title}[OTHR][#1]
  \setbeamertemplate{author}[OTHR][#1]
  \setbeamertemplate{institute}[OTHR][#1]
  \setbeamertemplate{date}[OTHR][#1]
  \setbeamertemplate{titlegraphic}[OTHR]
  \fi
}
%    \end{macrocode}
