      leftskip=\dim_eval:n {\beamer@leftmargin},
      rightskip=\c_@@_beamer_framesep_dim,
      wd=\paperwidth,
    ]{frametitle}
    \leavevmode\parbox[t]
    {\dim_eval:n {\linewidth- \beamer@leftmargin-2\c_@@_beamer_framesep_dim-\box_wd:N \g_@@_logo_box}}{%
      \vskip1pt
      {\usebeamerfont{frametitle}\strut\insertframetitle}
