\msg_if_exist:nnF  {othr-ci} {deprecated-option} {
  \msg_new:nnn {othr-ci} {deprecated-option} {
    The~option~`#1`~is~deprecated~and~will~be~removed~in~the~future~as~it~is~obsolete!\\
    Please~remove~this~option~from~your~file.\\
    It~has~no~effect.
  }
}

