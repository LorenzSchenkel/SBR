% \begin{documentation}
% \subsection{Structures to simplify reproducing CI compliant slide layouts}
% OTHR-CI adds some environments to simplify the
% \end{documentation}
% \begin{implementation}
% picture block
% Power Point template is using 4 columns for the image and 10 columnes for the text block
%    \begin{macrocode}
\newenvironment<>{imageblock}[2][]{%
\setlength{\columnsep}{\z@}%
\addvspace{\medskipamount}
\begin{columns}#3[onlytextwidth,T]%
  \begin{column}{.3\linewidth}%
    #2
  \end{column}%
  \begin{column}{.7\linewidth}%
    \setbeamertemplate{block begin}[OTHR][colsep*=0pt,colsep=.75ex]
    \begin{block}{#1}
      }{%
    \end{block}%
  \end{column}%
\end{columns}
}

