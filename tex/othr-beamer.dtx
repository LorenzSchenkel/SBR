\NewDocumentCommand{\department}{O{#2}m}{
  \tl_if_blank:nTF {#2} {
    \def\insertdepartment{}
  } {
    \def\insertdepartment{\def\inst{\beamer@instinst}#2}
  }
  \def\beamer@shortdepartment{#1}
}
\department{}
