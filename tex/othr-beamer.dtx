% \begin{documentation}
% \DescribeKeyOption{frame-mode=shading/no-shading}{}
% The \option{frame-mode} is a custom option which is added by \pkg{OTHR-CI} to be used with the \env{frame} environment.
% It can be used to enable the blue shaded background, which is used by the block environment using default settings.
% This would use the \value{shading} whereas \value{no-shading} can be used to locally overwrite the automatic selecting by the \env{block} environment.
% \end{documentation}
% \begin{implementation}
%    \begin{macrocode}
\define@key{beamerframe}{frame-mode}{
  \keys_set:nn {ptxcd/beamer/outer} {
    frame-mode=#1
  }
}

\defbeamertemplate{background~canvas}{OTHR-shading}{
  \skip_horizontal:n {\beamer@leftmargin}
  \vbox_to_ht:nn {\paperheight} {
    \skip_vertical:n {8\c__ptxcd_beamer_framesep_dim}
    \begin{beamercolorbox}[wd=\paperwidth,ht=.72\paperheight,dp=0pt]{OTHR~background~shading}
    \end{beamercolorbox}
    \vfill
    \null
  }
}

\cs_new:cpn {ps@OTHR-shading} {
  \setbeamertemplate{background~canvas}[OTHR-shading]
  \@nameuse{ps@navigation}
}

\keys_define:nn {ptxcd/beamer/outer} {
  frame-mode .choice:,
  frame-mode / shading .code:n = \thispagestyle{OTHR-shading},
  frame-mode / no-shading .code:n = \bool_set_false:N \l_@@_block_auto_pagestyle_bool
}

\newtranslation[to = German]{CONTACT}{KONTAKT}

\newcommand*{\columnsepbox}[2][\fullheightblockheight]{%
  \leavevmode\rotatebox[origin=tr]{90}{\makebox[#1]{\small\hrulefill\hspace{1ex}\raisebox{-.5\height}{#2}}}%
  \hfill
}

\newenvironment<>{contactblock}[1]{%
\begin{actionenv}#2%
  \def\insertblocktitle{#1}%
  \par%
  \hbox_set:Nw  \l_@@_tmpa_box
  \begin{minipage}[t][.5\paperheight]{\dim_eval:n {\linewidth-2.5cm}}
    \usebeamercolor*{contact~block}
    \usebeamerfont*{contact~block}
    \color{fg}
    \setlength{\premulticols}{0pt}
    \setlength{\topskip}{0pt}
    \begin{multicols}{2}
      \setlength{\parindent}{\z@}
      }{
      \vfill\null
    \end{multicols}
  \end{minipage}
  \hbox_set_end:
  \hbox_set:Nn \l_@@_tmpa_box {
    \begin{beamercolorbox}[wd=.875\paperwidth,dp=0pt,colsep=5mm,vmode]{contact~ block}
      \vbox_to_ht:nn {0.5833\paperheight} {
        \vskip0pt\par
        \ifx\insertblocktitle\@empty
          \else
          {\usebeamerfont*{contact~ block~ title}\insertblocktitle\par}
        \fi
        \vskip\baselineskip
        \columnsepbox[.32\paperheight]{\translate{CONTACT}}
        \hbox_unpack_drop:N  \l_@@_tmpa_box
        \par\vfill
      }
    \end{beamercolorbox}
  }
  \usebeamercolor{contact~block}
  \_@@_box_use_background_pattern:Nnn \l_@@_tmpa_box {7.5mm} {bg}
\end{actionenv}
}

\newcommand*{\contactEntry}[2]{
  \par
  \leavevmode\raisebox{-.5\height}{\makebox[5mm]{\LARGE#1}}\hfill
  \raisebox{-.5\height}{\parbox{\dim_eval:n {\linewidth-7.5mm}}{#2}}
  \par\vskip\baselineskip
}

\newcommand{\contactAddress}[1]{
  \contactEntry{\faMapMarker*}{#1}
}

\newcommand{\contactEmail}[1]{
  \contactEntry{\faEnvelope[regular]}{#1}
}
\newcommand{\contactPhone}[1]{
  \contactEntry{\faPhone}{#1}
}

\newcommand*{\contactLink}[1]{
  \contactEntry{\faLink}{#1}
}

