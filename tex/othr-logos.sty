\ProvidesPackage{othr-logos}[2025-05-22 v0.01-dev  logo setup for OTH Regensburg CI]

\RequirePackage{xkeyval}

\ExplSyntaxOn
\tl_new:N \g__ptxcd_logo_mode_tl
\tl_gset:Nn \g__ptxcd_logo_mode_tl {extended}


\keys_define:nn {ptxcd/othr-logos} {
	accept-missing-logos .bool_gset:N = \g_ptxcd_logo_workaround_bool,
	accept-missing-logos .usage:n = load,
	accept-missing-logos .default:n = true,
	department .choice:,
	department / default .code:n = \str_gset:Nn \g_ptxcd_department_str {default},
	%<class>  department .initial:n = default,
	department / unknown .code:n = {
		\str_gset:NV \g_ptxcd_department_str \l_keys_value_tl
		\tl_if_in:VnTF \g_ptxcd_department_str {OTHR} {
			\tl_gset:Nn \g__ptxcd_logo_mode_tl {basic}
		} {
			\tl_gset:Nn \g__ptxcd_logo_mode_tl {extended}
		}
	},
	logofile .tl_gset:N = \g_ptxcd_logofile_tl,
	short-logofile .tl_gset:N = \g_@@_logofile_short_tl,
	departmentlogofile .tl_gset:N = \g_ptxcd_department_logofile_tl,
	departmentlogofile .initial:n = {OTHR_ \g_ptxcd_department_str _Logo},
	logostyle .choices:nn = {empty,flat,dynamic,user}{\tl_gset_eq:NN \g__ptxcd_logostyle_tl \l_keys_choice_tl},
	logostyle .initial:n = flat,
	useDepartmentLogo .meta:n = {flat-logofile=OTHR_ \g_ptxcd_department_str _Logo},
	useOTHRLogo .code:n = \PackageWarning{othr-logos}{deprecated~ option~ useOTHRLogo}
}

\ProcessKeyOptions[ptxcd/othr-logos]

\newcommand*{\SetupOTHRLogos}[1]{\keys_set:nn {ptxcd/othr-logos} {#1}}

\str_if_exist:NF \g_ptxcd_department_str {
  \str_new:N \g_ptxcd_department_str
  \str_gset:Nn \g_ptxcd_department_str {default}
  \tl_if_blank:VT \g_ptxcd_logofile_tl  {
  	\tl_gset:Nn\g_ptxcd_logofile_tl {default}
  }
}

\ExplSyntaxOff

\RequirePackage{graphicx}
\RequirePackage{pdftexcmds}
%
\newlength{\extendedlogosmall}
\setlength{\extendedlogosmall}{16mm}
\newlength{\extendedlogonormal}
\setlength{\extendedlogonormal}{20mm}
\newlength{\extendedlogolarge}
\setlength{\extendedlogolarge}{24mm}
\newlength{\extendedlogohuge}
\setlength{\extendedlogohuge}{28mm}
%
\newlength{\basiclogosmall}
\setlength{\basiclogosmall}{12mm}
\newlength{\basiclogonormal}
\setlength{\basiclogonormal}{16mm}
\newlength{\basiclogolarge}
\setlength{\basiclogolarge}{20mm}
\newlength{\basiclogohuge}
\setlength{\basiclogohuge}{24mm}
%
\ExplSyntaxOn
\cs_new:Nn \__ptxcd_loadOTHRCompatibilityLogo_aux:nnn{
			  \bool_if:NTF \g_ptxcd_logo_workaround_bool {
			    \file_if_exist:nTF {#3.pdf}
			    \use_ii:nn
			    \use_i:nn
			  } {
			    \use_ii:nn
			  }
			  {
			  	#1
			  	}
			  {\includegraphics[#2]{#3}}
}

\clist_map_inline:nn {small,normal,large,huge} {
	\cs_new:cpn {OfficialLogo\text_titlecase_first:n {#1}} {
		\use:c  {logo\text_titlecase_first:n {#1}} * [ othr-logo_flat ]
	}
	\exp_args:Nc \NewDocumentCommand {logo\text_titlecase_first:n {#1}} {sO{\g_ptxcd_logofile_tl}}{
		{\IfBooleanT{##1}{\tl_set:Nn \g__ptxcd_logo_mode_tl {basic}}
		\__ptxcd_loadOTHRCompatibilityLogo_aux:nnn {
			\IfBooleanTF{##1}{
				{
					\setlength{\fboxsep}{0pt}
					\fbox{
						\rule{0pt}{\dim_use:c {\g__ptxcd_logo_mode_tl logo #1}}
						\rule{\dim_eval:n {\use:c {\g__ptxcd_logo_mode_tl logo #1}* 11 / 2}}{0pt}
					}
				}
			} {
				{
					\setlength{\fboxsep}{0pt}
					\fbox{
						\rule{0pt}{\dim_use:c {\g__ptxcd_logo_mode_tl logo #1}}
						\rule{\dim_eval:n {\use:c {\g__ptxcd_logo_mode_tl logo #1}* 6 / 2}}{0pt}
					}
				}
			}
		} {height=\dim_use:c {\g__ptxcd_logo_mode_tl logo #1}} {##2}
		}
	}
	\cs_new:cpn {kurzlogo\text_titlecase_first:n {#1}} {
		\use:c  {logo\text_titlecase_first:n {#1}} * [\g_@@_logofile_short_tl]
	}
	\cs_new:cpn {dynamiclogo\text_titlecase_first:n {#1}} {
		\use:c  {logo\text_titlecase_first:n {#1}} [\g_ptxcd_department_logofile_tl]
	}
	\cs_new:cpn {classiclogo\text_titlecase_first:n {#1}OTHR} {
			\use:c  {logo\text_titlecase_first:n {#1}} * [\classiclogoFile]
	}
}

\newcommand*{\classiclogoFile}{OTHR_OTHR_Logo}

\NewDocumentCommand{\OfficialLogoFlexible}{O{demo}}{
 	\__ptxcd_loadOTHRCompatibilityLogo_aux:nnn {
		\includegraphics[#1]{example-image}
	} {#1} { othr-logo_flat }
}
\NewDocumentCommand{\logoFlexibleOTHR}{O{demo}}{
	\begingroup
		\str_set:Nn \g_ptxcd_department_str {OTHR}
		\__ptxcd_loadOTHRCompatibilityLogo_aux:nnn {
			\includegraphics[#1]{example-image}
		} {#1} {\g_ptxcd_logofile_tl}
	\endgroup
}
\NewDocumentCommand{\kurzlogoFlexibleOTHR}{O{demo}}{
	\begingroup
		\str_set:Nn \g_ptxcd_department_str {OTHR}
	\__ptxcd_loadOTHRCompatibilityLogo_aux:nnn {
		\includegraphics[#1]{example-image}
	} {#1} {\g_@@_logofile_short_tl}
	\endgroup
}

\NewDocumentCommand{\dynamiclogoFlexible}{O{demo}}{
 	\__ptxcd_loadOTHRCompatibilityLogo_aux:nnn {
		\includegraphics[#1]{example-image}
	} {#1} {\g_ptxcd_department_logofile_tl}
}

\NewDocumentCommand{\logoFlexible}{O{demo}}{\use:c {\g__ptxcd_logostyle_tl logoFlexible}[#1]}

\str_case:Vn \g__ptxcd_logostyle_tl {
	{empty} {}
	{flat} {\keys_set:nn  {ptxcd/othr-logos} {logofile = othr-logo_flat}}
	{dynamic} {\keys_set:nn  {ptxcd/othr-logos} {logofile = OTHR_ \g_ptxcd_department_str _Logo}}
	{user} {
		\def\logo \userlogoSmall
		\clist_map_inline:nn {small,normal,large,huge,flexible} {
			\cs_set:cpn {logo\text_titlecase_first:n {#1}} {\use:c {userlogo\text_titlecase_first:n {#1}}}
			\cs_set:cpn {OfficialLogo\text_titlecase_first:n {#1}} {\use:c {userlogo\text_titlecase_first:n {#1}}}
	}
	}
}

\NewDocumentCommand{\defineUserLogo}{O{20mm}m}{%
    \newcommand*{\userlogoSmall}{{\includegraphics[height=.75\dimexpr#1]{#2}}}
    \newcommand*{\userlogoNormal}{{\includegraphics[height=#1]{#2}}}
    \newcommand*{\userlogoLarge}{{\includegraphics[height=.8\dimexpr#1]{#2}}}
    \newcommand*{\userlogoHuge}{{\includegraphics[height=.666\dimexpr#1]{#2}}}
    \newcommand*{\userlogoFlexible}[1][draft]{{\includegraphics[##1]{#2}}}
}


\ExplSyntaxOff
\endinput
